# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#1197, it is determined that Pipfile.lock is expected to be committed in version control.
#   However, in case of a library, you should ignore Pipfile.lock in a .gitignore:
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is expected to be committed in version control.
#   However, in case of a library, you should ignore poetry.lock in a .gitignore:
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is expected to be committed in version control.
#   However, in case of a library, you should ignore pdm.lock in a .gitignore:
#pdm.lock

